# Pinata API credentials — get from https://app.pinata.cloud/developers/api-keys
# Create a key with "pinFileToIPFS" permission.
# WARNING: VITE_* vars are embedded in the browser bundle and visible in DevTools.
# For production, proxy uploads through a backend instead of exposing keys here.
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here

# Contract addresses — defaults to deployed Sepolia addresses if not set.
VITE_REGISTRY_ADDRESS=0x3193c25d8A69758B8836c47f6105d4cD6d46563e
VITE_CREDENTIAL_ADDRESS=0x403493392013806b3dC5Bea7C031e02E641ad336
